[Interface]
{% if wg_tunnel_address_v6 %}
Address = {{ wg_tunnel_address }}, {{ wg_tunnel_address_v6 }}
{% else %}
Address = {{ wg_tunnel_address }}
{% endif %}
ListenPort = {{ wg_listen_port }}
MTU = {{ wg_mtu }}
PrivateKey = {{ wg_private_key }}

[Peer]
# pfSense — no Endpoint set (learned from incoming handshake via PersistentKeepalive)
PublicKey = {{ secrets.pfsense_wg_public_key }}
AllowedIPs = {{ wg_peer_allowed_ips }}
