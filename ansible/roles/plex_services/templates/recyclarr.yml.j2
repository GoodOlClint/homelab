# Recyclarr configuration — TRaSH Guide quality profiles
# Deployed to /opt/plex-services/recyclarr/recyclarr.yml by Ansible
# Syncs quality profiles to Sonarr and Radarr on CRON_SCHEDULE (@daily)

sonarr:
  sonarr:
    base_url: http://sonarr:8989
    api_key: "{{ arr_api_keys.sonarr | default('changeme') }}"

    include:
      - template: sonarr-quality-definition-series
      - template: sonarr-v4-quality-profile-web-1080p
      - template: sonarr-v4-custom-formats-web-1080p

    quality_profiles:
      - name: WEB-1080p
        reset_unmatched_scores:
          enabled: true

radarr:
  radarr:
    base_url: http://radarr:7878
    api_key: "{{ arr_api_keys.radarr | default('changeme') }}"

    include:
      - template: radarr-quality-definition-movie
      - template: radarr-v4-quality-profile-hd-bluray-web
      - template: radarr-v4-custom-formats-hd-bluray-web

    quality_profiles:
      - name: HD Bluray + WEB
        reset_unmatched_scores:
          enabled: true
