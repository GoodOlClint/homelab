# Authentik secrets — rendered by Infisical Agent
# Shared by authentik-postgres, authentik-server, and authentik-worker
{{'{{'}} with secret "{{ infisical_agent_project_id }}" "{{ infisical_agent_env_slug }}" "/docker" {{'}}'}}
{{'{{'}}- range . {{'}}'}}
{{'{{'}}- if eq .Key "authentik_secret_key" {{'}}'}}
AUTHENTIK_SECRET_KEY={{'{{'}} .Value {{'}}'}}
{{'{{'}}- end {{'}}'}}
{{'{{'}}- if eq .Key "authentik_postgres_password" {{'}}'}}
AUTHENTIK_POSTGRESQL__PASSWORD={{'{{'}} .Value {{'}}'}}
POSTGRES_PASSWORD={{'{{'}} .Value {{'}}'}}
{{'{{'}}- end {{'}}'}}
{{'{{'}}- end {{'}}'}}
{{'{{'}} end {{'}}'}}
