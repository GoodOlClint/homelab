# Cloudflared tunnel token — rendered by Infisical Agent
# Maps CLOUDFLARED_TUNNEL_TOKEN → TUNNEL_TOKEN for container consumption
{{'{{'}} with secret "{{ infisical_agent_project_id }}" "{{ infisical_agent_env_slug }}" "/plex-services" {{'}}'}}
{{'{{'}}- range . {{'}}'}}
{{'{{'}}- if eq .Key "CLOUDFLARED_TUNNEL_TOKEN" {{'}}'}}
TUNNEL_TOKEN={{'{{'}} .Value {{'}}'}}
{{'{{'}}- end {{'}}'}}
{{'{{'}}- end {{'}}'}}
{{'{{'}} end {{'}}'}}
