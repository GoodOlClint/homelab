# Infisical Agent config for {{ infisical_identity_name }}
# Auto-generated by Ansible — do not edit manually

infisical:
  address: "{{ infisical_agent_url }}"

auth:
  type: "universal-auth"
  config:
    client-id: "{{ infisical_config_dir }}/client-id"
    client-secret: "{{ infisical_config_dir }}/client-secret"

sinks:
  - type: "file"
    config:
      path: "/var/run/infisical/access-token"

templates:
{% for tpl in infisical_agent_templates %}
  - source-path: "{{ infisical_templates_dir }}/{{ tpl.name }}.tpl"
    destination-path: "{{ tpl.dest_path }}"
    config:
      polling-interval: "{{ infisical_agent_refresh_interval }}"
{% if tpl.post_command is defined %}
      execute:
        command: "{{ tpl.post_command }}"
{% endif %}
{% endfor %}
