services:
{# Radarr/Sonarr — migrated to plex-services VM #}
{#
  radarr:
    container_name: radarr
    image: ghcr.io/hotio/radarr:latest
    restart: unless-stopped
    logging:
      driver: json-file
    ports:
      - 7878:7878
    environment:
      - PUID=2001
      - PGID=2000
      - UMASK=002
      - TZ=America/Chicago
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - radarr_config:/config
      - plex_media:/data
  sonarr:
    container_name: sonarr
    image: ghcr.io/hotio/sonarr:latest
    restart: unless-stopped
    logging:
      driver: json-file
    ports:
      - 8989:8989
    environment:
      - PUID=2002
      - PGID=2000
      - UMASK=002
      - TZ=America/Chicago
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - sonarr_config:/config
      - plex_media:/data
#}
{# Legacy services — migrated to plex-services VM #}
{#
  bazarr:
    container_name: bazarr
    image: hotio/bazarr:latest
    restart: unless-stopped
    logging:
      driver: json-file
    ports:
      - 6767:6767
    environment:
      - PUID=2004
      - PGID=988
      - TZ=America/Chicago
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - bazarr_config:/config
      - plex_media:/data
  prowlarr:
    container_name: prowlarr
    image: hotio/prowlarr:latest
    restart: unless-stopped
    logging:
      driver: json-file
    ports:
      - 9696:9696
    environment:
      - PUID=2005
      - PGID=988
      - UMASK=002
      - TZ=America/Chicago
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - prowlarr_config:/config
      - plex_media:/data
  tautulli:
    container_name: tautulli
    image: hotio/tautulli:latest
    restart: unless-stopped
    logging:
      driver: json-file
    ports:
      - 8181:8181
    environment:
      - PUID=2006
      - PGID=988
      - TZ=America/Chicago
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - tautulli_config:/config
      - plex_media:/data
  cloudflared:
    image: cloudflare/cloudflared:latest
    restart: unless-stopped
    command: >-
      tunnel --no-autoupdate run --token
      ${CLOUDFLARED_TUNNEL_TOKEN}
  readarr:
    container_name: readarr
    image: hotio/readarr:latest
    restart: unless-stopped
    ports:
      - "8787:8787"
    environment:
      - PUID=2007
      - PGID=988
      - UMASK=002
      - TZ=America/Chicago
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - readarr_config:/config
      - plex_media:/data
  lidarr:
    container_name: lidarr
    image: hotio/lidarr:latest
    restart: unless-stopped
    ports:
      - "8686:8686"
    environment:
      - PUID=2008
      - PGID=988
      - TZ=America/Chicago
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - lidarr_config:/config
      - plex_media:/data
  sabnzbd:
    container_name: sabnzbd
    image: hotio/sabnzbd:latest
    restart: unless-stopped
    logging:
      driver: json-file
    ports:
      - "8080:8080"
    environment:
      - PUID=2003
      - PGID=988
      - UMASK=002
      - TZ=America/Chicago
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - sabnzbd_config:/config
      - plex_media:/data:rw
  plex-meta-manager:
    container_name: plex-meta-manager
    image: meisnate12/plex-meta-manager:latest
    restart: unless-stopped
    environment:
      - PUID=1000
      - PGID=988
      - TZ=America/Chicago
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - plex-meta-manager_config:/config:rw
  ombi:
    image: linuxserver/ombi:latest
    container_name: ombi
    restart: unless-stopped
    logging:
      driver: json-file
    depends_on:
      - ombi-mariadb
    environment:
      - PUID=1000
      - PGID=988
      - TZ=America/Chicago
    volumes:
      - ombi_config:/config
    ports:
      - 3579:3579
  ombi-mariadb:
    image: mariadb:latest
    container_name: ombi-mariadb
    restart: unless-stopped
    logging:
      driver: json-file
    environment:
      - "MARIADB_USER=ombi"
      - "MARIADB_PASSWORD=ombi"
      - "MARIADB_DATABASE=ombi"
      - "MARIADB_RANDOM_ROOT_PASSWORD=yes"
      - TZ=America/Chicago
    volumes:
      - "/docker/appdata/ombi-mariadb:/var/lib/mysql"
    ports:
      - 3306:3306
#}
  kiwix:
    image: ghcr.io/kiwix/kiwix-serve:latest
    container_name: kiwix
    restart: unless-stopped
    ports:
      - 8090:8080
    environment:
      - TZ={{ kiwix_timezone }}
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - kiwix_config:/data
    command:
      - '*.zim'
  boinc:
    image: linuxserver/boinc:latest
    container_name: boinc
    runtime: nvidia
    restart: unless-stopped
    ports:
      - 7080:8080
      - 7081:8181
      - 31416:31416
    security_opt:
      - seccomp:unconfined #optional
    environment:
      - NVIDIA_VISIBLE_DEVICES=all
      - NVIDIA_DRIVER_CAPABILITIES=all
      - PUID={{ boinc_user }}
      - PGID={{ boinc_group }}
      - TZ={{ boinc_timezone }}
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - boinc_config:/config
  doge-node:
    container_name: doge-node
    image: goodolclint/dogecoin-node:latest
    restart: unless-stopped
    ports:
      - 22555:22555
      - 3000:3000
    environment:
      - TZ={{ doge_node_timezone }}
    volumes:
      - doge-node_config:/data
  valheim:
    container_name: valheim
    image: lloesche/valheim-server:latest
    restart: unless-stopped
    cap_add:
      - sys_nice
    ports:
      - "2456-2458:2456-2458/udp"
    env_file:
      - /etc/infisical/secrets/docker-valheim.env
    environment:
      - TZ={{ timezone }}
      - SERVER_NAME={{ valheim_server_name }}
      - WORLD_NAME={{ valheim_world_name }}
      - SERVER_PUBLIC={{ valheim_server_public | default('false') }}
      - BACKUPS_ENABLED=true
      - BACKUPS_CRON=0 */6 * * *
      - BACKUPS_MAX_COUNT=10
      - UPDATE_CRON=0 4 * * *
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - valheim_config:/config
      - valheim_data:/opt/valheim

volumes:
{# Radarr/Sonarr volumes — migrated to plex-services VM #}
{#
  radarr_config:
    driver: local
    driver_opts:
      type: nfs
      o: "addr=NFS_SERVER,nfsvers=4,rsize=1048576,wsize=1048576,hard,intr,timeo=600"
      device: ":NFS_PATH/radarr"
  sonarr_config:
    driver: local
    driver_opts:
      type: nfs
      o: "addr=NFS_SERVER,nfsvers=4,rsize=1048576,wsize=1048576,hard,intr,timeo=600"
      device: ":NFS_PATH/sonarr"
#}
