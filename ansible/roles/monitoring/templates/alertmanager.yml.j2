global:
  resolve_timeout: 5m

route:
  group_by: ['alertname', 'severity']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  receiver: 'default'
  routes:
    - match:
        severity: critical
      receiver: 'critical'
      repeat_interval: 1h
    - match:
        severity: warning
      receiver: 'default'
      repeat_interval: 4h

receivers:
  - name: 'default'
{% if alertmanager_webhook_url is defined and alertmanager_webhook_url %}
    webhook_configs:
      - url: '{{ alertmanager_webhook_url }}'
        send_resolved: true
{% endif %}
{% if alertmanager_email_to is defined and alertmanager_email_to %}
    email_configs:
      - to: '{{ alertmanager_email_to }}'
        from: '{{ alertmanager_email_from | default("alertmanager@homelab.local") }}'
        smarthost: '{{ alertmanager_smtp_smarthost | default("localhost:25") }}'
        require_tls: {{ alertmanager_smtp_require_tls | default('false') }}
        send_resolved: true
{% endif %}

  - name: 'critical'
{% if alertmanager_webhook_url is defined and alertmanager_webhook_url %}
    webhook_configs:
      - url: '{{ alertmanager_webhook_url }}'
        send_resolved: true
{% endif %}
{% if alertmanager_email_to is defined and alertmanager_email_to %}
    email_configs:
      - to: '{{ alertmanager_email_to }}'
        from: '{{ alertmanager_email_from | default("alertmanager@homelab.local") }}'
        smarthost: '{{ alertmanager_smtp_smarthost | default("localhost:25") }}'
        require_tls: {{ alertmanager_smtp_require_tls | default('false') }}
        send_resolved: true
{% endif %}

inhibit_rules:
  - source_match:
      severity: 'critical'
    target_match:
      severity: 'warning'
    equal: ['alertname', 'instance']
