{% raw %}
groups:
  - name: infrastructure
    rules:
      - alert: HostDown
        expr: up == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Host {{ $labels.instance }} is down"

      - alert: WireGuardPeerStale
        expr: time() - wireguard_latest_handshake_seconds > 180
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "WireGuard peer {{ $labels.public_key }} handshake older than 3 minutes"

      - alert: TLSCertExpiringSoon
        expr: probe_ssl_earliest_cert_expiry - time() < 86400 * 14
        for: 1h
        labels:
          severity: warning
        annotations:
          summary: "TLS certificate for {{ $labels.instance }} expires in less than 14 days"

      - alert: HighMemoryUsage
        expr: (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) > 0.9
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Memory usage above 90% on {{ $labels.instance }}"

      - alert: HighDiskUsage
        expr: (1 - node_filesystem_avail_bytes{fstype!="tmpfs"} / node_filesystem_size_bytes{fstype!="tmpfs"}) > 0.85
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Disk usage above 85% on {{ $labels.instance }}:{{ $labels.mountpoint }}"

      - alert: PBSBackupStale
        expr: time() - pbs_snapshot_timestamp > 86400 * 2
        for: 1h
        labels:
          severity: warning
        annotations:
          summary: "PBS backup for {{ $labels.namespace }} is older than 2 days"

  - name: services
    rules:
      - alert: PlexDown
        expr: probe_success{job="blackbox-http", instance=~".*:32400.*"} == 0
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "Plex is unreachable"

      - alert: DNSResolutionFailure
        expr: probe_success{job="blackbox-dns"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "DNS resolution failing for {{ $labels.zone }}"

  - name: isp
    rules:
      - alert: ModemT3Timeouts
        expr: increase(modem_t3_timeouts_total[15m]) > 5
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Cox modem T3 timeouts detected"
          description: "{{ $value }} T3 timeouts in the last 15 minutes"

      - alert: ModemT4Timeouts
        expr: increase(modem_t4_timeouts_total[15m]) > 3
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "Cox modem T4 timeouts detected"
          description: "{{ $value }} T4 timeouts in the last 15 minutes — possible service disruption"

      - alert: HighPacketLoss
        expr: ping_percent_packet_loss{url=~"8.8.8.8|1.1.1.1"} > 5
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High packet loss to {{ $labels.url }}"
          description: "{{ $value }}% packet loss over 5 minutes"

      - alert: HighLatency
        expr: probe_icmp_duration_seconds{job="blackbox-ping",instance=~"8.8.8.8|1.1.1.1",phase="rtt"} > 0.1
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "High latency to {{ $labels.instance }}"
          description: "RTT {{ $value }}s (>100ms) over 5 minutes"
{% endraw %}
