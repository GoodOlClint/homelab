
// TSIG key for pfSense DHCP dynamic DNS updates (RFC 2136)
key "dhcp-update-key" {
    algorithm hmac-sha256;
    secret "{{ secrets.infrastructure.bind_tsig_key_secret }}";
};

// Forward zones — one per VLAN served by BIND
{% for vlan, zone in dns_zones.items() %}
zone "{{ zone.zone }}" {
    type master;
    file "/etc/bind/db.{{ zone.zone }}";
    allow-update { key "dhcp-update-key"; };
};
{% endfor %}

// Reverse zones — PTR records for each VLAN subnet
{% for vlan, zone in dns_zones.items() %}
zone "{{ zone.vlan_id }}.{{ ipv4_prefix_reversed }}.in-addr.arpa" {
    type master;
    file "/etc/bind/db.{{ zone.vlan_id }}.{{ ipv4_prefix_reversed }}.in-addr.arpa";
    allow-update { key "dhcp-update-key"; };
};
{% endfor %}
