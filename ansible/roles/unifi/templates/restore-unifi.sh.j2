#!/bin/bash
# UniFi Controller Restore Script
# Managed by Ansible - do not edit manually

set -euo pipefail

if [ $# -ne 1 ]; then
    echo "Usage: $0 <backup-file.unf>"
    echo ""
    echo "Available backups:"
    ls -lh {{ unifi_backup_dir }}/*.unf 2>/dev/null || echo "  No backups found"
    exit 1
fi

BACKUP_FILE="$1"
UNIFI_DIR="{{ unifi_base_dir }}"
RESTORE_DIR="/tmp/unifi-restore-$$"

if [ ! -f "${BACKUP_FILE}" ]; then
    echo "Error: Backup file not found: ${BACKUP_FILE}"
    exit 1
fi

echo "WARNING: This will restore UniFi Controller from backup and overwrite current configuration!"
echo "Backup file: ${BACKUP_FILE}"
echo ""
read -p "Are you sure you want to continue? (yes/no): " -r
if [[ ! $REPLY =~ ^yes$ ]]; then
    echo "Restore cancelled."
    exit 0
fi

echo "Starting UniFi Controller restore at $(date)"

# Stop UniFi service
echo "Stopping UniFi service..."
systemctl stop unifi

# Create temporary restore directory
mkdir -p "${RESTORE_DIR}"

# Extract backup
echo "Extracting backup..."
tar -xzf "${BACKUP_FILE}" -C "${RESTORE_DIR}"

# Find the MongoDB dump directory
MONGO_DUMP_DIR=$(find "${RESTORE_DIR}" -type d -name "mongo-*" | head -1)

if [ -z "${MONGO_DUMP_DIR}" ]; then
    echo "Error: MongoDB dump not found in backup"
    rm -rf "${RESTORE_DIR}"
    exit 1
fi

# Restore MongoDB databases
echo "Restoring MongoDB databases..."
mongorestore --drop --db unifi "${MONGO_DUMP_DIR}/unifi"
mongorestore --drop --db unifi_stat "${MONGO_DUMP_DIR}/unifi_stat"

# Restore UniFi data files
echo "Restoring UniFi configuration files..."
if [ -d "${RESTORE_DIR}/sites" ]; then
    cp -r "${RESTORE_DIR}/sites" "${UNIFI_DIR}/data/"
fi
if [ -f "${RESTORE_DIR}/system.properties" ]; then
    cp "${RESTORE_DIR}/system.properties" "${UNIFI_DIR}/data/"
fi

# Fix permissions
echo "Fixing permissions..."
chown -R {{ unifi_user }}:{{ unifi_group }} "${UNIFI_DIR}/data"

# Clean up
rm -rf "${RESTORE_DIR}"

# Start UniFi service
echo "Starting UniFi service..."
systemctl start unifi

echo "Restore completed successfully!"
echo "UniFi Controller should be available in a few moments at https://$(hostname):8443"
