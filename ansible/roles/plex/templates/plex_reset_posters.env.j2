# Plex poster reset configuration — managed by Ansible
# Used by /opt/media-scripts/Plex/reset-posters-plex.py

# Plex connection (local — no SSL needed)
PLEXAPI_AUTH_SERVER_BASEURL=http://127.0.0.1:{{ plex_port | default(32400) }}
PLEXAPI_AUTH_SERVER_TOKEN=${PLEX_TOKEN}
PLEXAPI_PLEXAPI_TIMEOUT=360
PLEXAPI_LOG_LEVEL=INFO
PLEXAPI_LOG_PATH=plexapi.log
PLEXAPI_LOG_BACKUP_COUNT=3
PLEXAPI_LOG_ROTATE_BYTES=512000
PLEXAPI_LOG_SHOW_SECRETS=0

# Libraries to process (comma-separated)
LIBRARY_NAMES={{ plex_poster_reset_libraries }}

# Delay between API calls (seconds)
DELAY=0

# Resume tracking — critical for surviving reboots
TRACK_RESET_STATUS=1
FLUSH_STATUS_AT_START=0
RETAIN_RESET_STATUS_FILE=1

# Reset seasons and episodes too
RESET_SEASONS=1
RESET_EPISODES=1
RESET_SEASONS_WITH_SERIES=1

# Overlay handling
OVERRIDE_OVERLAY_STATUS=1

# Labels
TARGET_LABELS=
REMOVE_LABELS=0

# Don't dry run
DRY_RUN=0
